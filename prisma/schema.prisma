generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  claims        Claim[]
  workerProfile WorkerProfile?
  policies      Policy[]
  incomeClaims  IncomeClaim[]
  sessions      Session[]
  accounts      Account[]
}

model Claim {
  id                       String   @id @default(cuid())
  userId                   String
  user                     User     @relation(fields: [userId], references: [id])
  months_as_customer       Float
  age                      Float
  policy_bind_date         String
  policy_annual_premium    Float
  umbrella_limit           Float    @default(0)
  incident_type            String
  collision_type           String
  incident_severity        String
  authorities_contacted    String
  incident_hour_of_the_day Float
  number_of_vehicles_involved Float
  property_damage          String
  bodily_injuries          Float    @default(0)
  witnesses                Float
  police_report_available  String
  total_claim_amount       Float
  injury_claim             Float
  property_claim           Float
  vehicle_claim            Float
  auto_year                Float
  capital_gains            Float    @default(0)
  capital_loss             Float    @default(0)
  policy_deductable        Float    @default(1000)
  fraud_probability        Float
  riskScore                Float
  riskLevel                String
  is_fraud                 Boolean  @default(false)
  flags                    String   @default("[]")
  recommendation           String
  status                   String   @default("PENDING")
  adminNote                String?
  infoRequestNote          String?
  additionalDescription    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ModelWeights {
  id               String  @id @default(cuid())
  gpsConsistency   Float
  deviceIntegrity  Float
  claimBurstScore  Float
  networkOverlap   Float
  motionCoherence  Float
  normalizedAmount Float
  priorClaimsRate  Float
  descriptionLen   Float
  bias             Float
  trainedAt        DateTime @default(now())
  sampleCount      Int
}

model WorkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone           String
  city            String
  zone            String
  platform        String
  vehicleType     String
  weeklyIncome    Float
  avgHoursPerDay  Float
  workDaysPerWeek Int
  upiId           String
  trustScore      Float    @default(0.72)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  policies        Policy[]
}

model Policy {
  id               String        @id @default(cuid())
  userId           String
  profileId        String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          WorkerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  policyNumber     String        @unique
  status           String        @default("ACTIVE")
  weeklyPremium    Float
  weeklyCoverage   Float
  coverageHours    Int
  riskScore        Float
  riskLevel        String
  pricingBreakdown String        @default("[]")
  payoutChannel    String        @default("UPI")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  incomeClaims     IncomeClaim[]
}

model TriggerEvent {
  id               String        @id @default(cuid())
  externalId       String        @unique
  type             String
  severity         String
  city             String
  zone             String
  source           String
  title            String
  description      String
  impactHours      Float
  payoutMultiplier Float
  isActive         Boolean       @default(true)
  startsAt         DateTime
  endsAt           DateTime
  metadata         String        @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  incomeClaims     IncomeClaim[]
}

model IncomeClaim {
  id                 String       @id @default(cuid())
  userId             String
  policyId           String
  triggerEventId     String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy             Policy       @relation(fields: [policyId], references: [id], onDelete: Cascade)
  triggerEvent       TriggerEvent @relation(fields: [triggerEventId], references: [id], onDelete: Cascade)
  status             String       @default("AUTO_INITIATED")
  estimatedIncomeLoss Float
  approvedPayout     Float
  fraudScore         Float
  fraudLevel         String
  fraudFlags         String       @default("[]")
  validationSummary  String
  payoutReference    String?
  payoutChannel      String       @default("UPI")
  triggerSnapshot    String       @default("{}")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([policyId, triggerEventId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
